# Copy to .env before running:
#   cp .env.mainnet.example .env && docker compose up --build -d
#
# Or pick this file directly:
#   docker compose --env-file .env.mainnet.example -p module3-mainnet up --build -d

# Network selector — drives the indexer CLI and the dashboard's /api/config
NETWORK=mainnet

# Traefik host rule — must resolve to this VM (DNS A record)
DASHBOARD_HOST=module-3.vector.mainnet.apexfusion.org

# Indexer poll interval in seconds (default 60)
INDEXER_INTERVAL=60
