# Vector agent swarm — environment variables
#
# Loaded by systemd via EnvironmentFile=-%h/vector-agents/env
# Format: strict KEY=value, one per line. No `export`, no quotes needed
# unless the value contains whitespace, no shell expansion.
#
# Install:
#   cp env.example ~/vector-agents/env
#   chmod 600 ~/vector-agents/env
#   # then fill in the token below

# Long-lived OAuth token for headless Claude Code auth (generate with
# `claude setup-token`; one-year validity).
CLAUDE_CODE_OAUTH_TOKEN=
